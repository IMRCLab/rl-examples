<mujoco model="pololu">
  <compiler angle="radian" inertiafromgeom="true"/>

  <!-- Keep your timestep and integrator -->
  <option timestep="0.002" integrator="implicit" gravity="0 0 -9.81"/>

  <visual>
    <global azimuth="45" elevation="-30"/>
    <headlight ambient="0.3 0.3 0.3" diffuse="0.6 0.6 0.6"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge"
             rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3" markrgb="0.8 0.8 0.8"
             width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="10 10" reflectance="0"/>
    <!-- Wheel texture to visualize rotation -->
    <texture name="wheel_tex" type="2d" builtin="checker"
            rgb1="0.05 0.05 0.05" rgb2="0.9 0.9 0.9"
            width="256" height="256"/>

    <material name="wheel_mat" texture="wheel_tex"
              texrepeat="6 1" texuniform="true" reflectance="0.0"/>
  </asset>

  <worldbody>
    <!-- Slightly soft contact to behave well -->
    <geom name="floor" type="plane" size="0 0 0.05" material="groundplane"
          solref="0.002 1" solimp="0.95 0.99 0.001"/>

    <light pos="0 0 1.5" dir="0 0 -1" directional="true"/>

    <!-- Wheel radius is 0.016, so ~0.0161 keeps only 0.1mm clearance -->
    <body name="chassis" pos="-0.0445 0 0.0161">
      <freejoint name="root"/>
      <camera name="track_cam" mode="track" pos="0 -0.6 0.25" xyaxes="1 0 0 0 0.6 1"/>

      <!-- Main chassis body-->
      <geom name="body" type="cylinder"
            size="0.0445 0.01"
            pos="-0.006 0 0.0"
            rgba="1.0 1.0 1.0 1.0"
            mass="0.140"/>

      <!-- Extra rear mass ("battery pack") to move COM back without changing geometry much -->
      <geom name="rear_mass" type="box"
            size="0.018 0.020 0.008"
            pos="-0.030 0 0.006"
            rgba="0.2 0.2 0.2 0.0"
            mass="0.040"/>

      <!-- Left wheel -->
      <body name="left_wheel" pos="0.0 0.0445 0.0">
        <joint name="left_wheel_joint" type="hinge" axis="0 1 0"
               damping="0.2" armature="0.005" frictionloss="0.02"/>
        <geom name="left_wheel_geom" type="cylinder" size="0.016 0.002"
              rgba="1 1 1 1" euler="1.5708 0 0"
              material="wheel_mat"
              friction="0.7 0.001 0.0001" 
              />  
        <!-- Visual marker to show wheel rotation (no collisions) -->
        <geom name="left_wheel_marker" type="box"
              size="0.0015 0.0006 0.0015"
              pos="0 0 0.016"
              rgba="1 0 0 1"
              contype="0" conaffinity="0"/>

      </body>

      <!-- Right wheel -->
      <body name="right_wheel" pos="0.0 -0.0445 0.0">
        <joint name="right_wheel_joint" type="hinge" axis="0 1 0"
               damping="0.2" armature="0.005" frictionloss="0.02"/>
        <geom name="right_wheel_geom" type="cylinder" size="0.016 0.002"
              rgba="1 1 1 1" euler="1.5708 0 0"
              material="wheel_mat"
              friction="0.7 0.001 0.0001" 
              />
          <!-- Visual marker to show wheel rotation (no collisions) -->
          <geom name="right_wheel_marker" type="box"
            size="0.0015 0.0006 0.0015"
            pos="0 0 0.016"
            rgba="1 0 0 1"
            contype="0" conaffinity="0"/>

      </body>
      <body name="caster" pos="-0.041 0.0 -0.01">
        <geom name="caster_geom" type="sphere" size="0.0055"
              rgba="0.5 0.5 0.5 1"
              friction="0.0 0.0 0.0"
              />
      </body>

    </body>
  </worldbody>

  <actuator>
    <velocity name="left_motor"  joint="left_wheel_joint"  kv="0.5" ctrlrange="-157.08 157.08"/>
    <velocity name="right_motor" joint="right_wheel_joint" kv="0.5" ctrlrange="-157.08 157.08"/>
  </actuator>

</mujoco>
